"""
signup_sheet_builder.py

Core library for Makersmiths sign-up sheet generation.
Provides YAML parsing, QR code generation, and HTML rendering functions.
Imported by signup-sheet.py (CLI) and tests.
"""

import base64
import io
from pathlib import Path

import qrcode
import yaml
from jinja2 import Environment, FileSystemLoader


def load_yaml(source) -> dict:
    """Load YAML from a file path or open file object.

    Args:
        source: File path (str or Path) or a readable file object (e.g. sys.stdin).

    Returns:
        Parsed YAML content as a dict.
    """
    if hasattr(source, "read"):
        return yaml.safe_load(source)
    with open(source, "r", encoding="utf-8") as f:
        return yaml.safe_load(f)


def detect_format(data: dict) -> str:
    """Return the root key used to access shop data.

    Args:
        data: Top-level dict parsed from YAML.

    Returns:
        One of 'opportunity', 'opportunities', or 'tasks_list'.

    Raises:
        ValueError: If none of the expected root keys are present.
    """
    for key in ("opportunity", "opportunities", "tasks_list"):
        if key in data:
            return key
    raise ValueError(
        f"Unknown YAML format: root key must be 'opportunity', 'opportunities', or 'tasks_list', "
        f"got: {list(data)}"
    )


def _is_real_task(t) -> bool:
    """Return True if t is a real task (not a TBD placeholder or empty).

    Args:
        t: A task entry — either a dict with a 'task' key or a plain string.

    Returns:
        True if the task name is non-empty and not literally "TBD".
    """
    if isinstance(t, dict):
        return (
            t.get("task", "").strip().upper() != "TBD"
            and t.get("task", "").strip() != ""
        )
    return str(t).strip().upper() != "TBD" and str(t).strip() != ""


def _build_task_entry(t) -> dict:
    """Build a normalised task dict from a raw YAML task entry.

    Handles both rich dict entries (with task_id, frequency, etc.) and plain
    string entries, which are promoted to dicts with sentinel 'NA' values.

    Args:
        t: A raw YAML task — either a dict or a plain string.

    Returns:
        Dict with keys: name, task_id, frequency, last_date, instructions.
        Missing optional fields default to 'NA' or ''.
    """
    if isinstance(t, dict):
        instructions = t.get("instructions", "")
        return {
            "name": t.get("task", "???"),
            "task_id": t.get("task_id") or "NA",
            "frequency": t.get("frequency", "NA"),
            "last_date": t.get("last_date") or "NA",
            "instructions": (
                ""
                if not instructions or str(instructions).strip().upper() == "NA"
                else str(instructions).strip()
            ),
        }
    return {
        "name": str(t),
        "task_id": "NA",
        "frequency": "NA",
        "last_date": "NA",
        "instructions": "",
    }


def _process_location(loc: dict, skip_tbd: bool) -> dict | None:
    """Return a normalised location dict, or None if all tasks are TBD/empty.

    Also tolerates the 'stward' typo for the steward field.

    Args:
        loc: Raw location dict from YAML.
        skip_tbd: If True, returns None when all tasks are TBD or empty.

    Returns:
        Dict with keys: name, steward, tasks (list of task dicts from
        _build_task_entry). Returns None when skip_tbd is True and the
        location has no real tasks.
    """
    raw_tasks = loc.get("work_tasks", loc.get("task", [])) or []
    if skip_tbd and not any(_is_real_task(t) for t in raw_tasks):
        return None
    return {
        "name": loc.get("name", "???"),
        "steward": loc.get("steward", loc.get("stward", "???")),
        "tasks": [_build_task_entry(t) for t in raw_tasks if _is_real_task(t)],
    }


def extract_locations(data: dict, skip_tbd: bool = True) -> list:
    """Return list of location dicts extracted from YAML data.

    Walks the full shop → area → location hierarchy and flattens it into a
    flat list of location dicts, each containing its normalised task list.

    Args:
        data: Top-level dict parsed from YAML (any supported root-key format).
        skip_tbd: When True (default), locations whose tasks are all TBD or
            empty are silently omitted from the result.

    Returns:
        List of dicts, each with keys:
            - name (str): location name
            - steward (str): steward name (falls back to 'stward' typo key)
            - tasks (list[dict]): task entries from _build_task_entry()
    """
    fmt = detect_format(data)
    shop = data[fmt]["shop"]
    locations = []
    for area in shop.get("area", []):
        for loc in area.get("location", []):
            result = _process_location(loc, skip_tbd)
            if result is not None:
                locations.append(result)
    return locations


def make_qr_b64(url: str) -> str:
    """Generate a QR code image and return it as a base64-encoded PNG string.

    Args:
        url: The URL to encode in the QR code.

    Returns:
        Base64-encoded PNG bytes as a UTF-8 string, suitable for embedding in
        an HTML <img src="data:image/png;base64,..."> tag.
    """
    img = qrcode.make(url)
    buf = io.BytesIO()
    img.save(buf, format="PNG")
    return base64.b64encode(buf.getvalue()).decode("utf-8")


def attach_qr_codes(locations: list, qr_url: str) -> list:
    """Attach a QR code image to every task in the locations list.

    All tasks share a single QR code image generated from qr_url (the same
    placeholder URL appears on every task row — task-specific URLs are resolved
    at scan time via the bot).

    Args:
        locations: List of location dicts (as returned by extract_locations).
        qr_url: URL to encode in the QR code.

    Returns:
        The same locations list, with 'qr_b64' added to each task dict.
    """
    qr_b64 = make_qr_b64(qr_url)
    for loc in locations:
        for task in loc["tasks"]:
            task["qr_b64"] = qr_b64
    return locations


def _logo_data_uri(logo_path: str) -> str | None:
    """Return a base64 data URI for the logo image, or None if the file is missing.

    Args:
        logo_path: Path to the logo image file (PNG or JPEG).

    Returns:
        A data URI string ("data:image/<mime>;base64,...") ready for use as an
        HTML img src attribute, or None if the file does not exist.
    """
    p = Path(logo_path)
    if not p.exists():
        return None
    suffix = p.suffix.lower().lstrip(".")
    mime = "jpeg" if suffix in ("jpg", "jpeg") else suffix
    data = base64.b64encode(p.read_bytes()).decode("utf-8")
    return f"data:image/{mime};base64,{data}"


def render_sheet(template_path: str, locations: list, logo_path: str | None) -> str:
    """Render the Jinja2 template with location and task data.

    Args:
        template_path: Path to the .html.j2 Jinja2 template file.
        locations: List of location dicts (with tasks and qr_b64 attached).
        logo_path: Path to the logo image, or None to skip the logo.

    Returns:
        Rendered HTML string.
    """
    tmpl_file = Path(template_path)
    env = Environment(
        loader=FileSystemLoader(str(tmpl_file.parent)),
        autoescape=False,
    )
    template = env.get_template(tmpl_file.name)
    logo_uri = _logo_data_uri(logo_path) if logo_path else None
    return template.render(locations=locations, logo_path=logo_uri)
