#!/usr/bin/env bash
# Convert docs/requirements.md → docs/requirements.pdf
# Images are resolved relative to docs/ where the .png files live.
# Usage: bash scripts/requirements-to-pdf.sh [output.pdf]
#
# Two things to know:
#   --enable-local-file-access is required — wkhtmltopdf blocks local file reads by default, which would silently drop the images.
#   cd "$DOCS_DIR" matters — pandoc passes image paths to wkhtmltopdf relative to CWD, so you must be in docs/ when you run it, or the PNGs won't embed.

set -euo pipefail

DOCS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../docs" && pwd)"
INPUT="$DOCS_DIR/requirements.md"
OUTPUT="${1:-$DOCS_DIR/requirements.pdf}"

cd "$DOCS_DIR" # pandoc resolves image paths relative to CWD

pandoc \ 
--from=gfm \ 
--to=pdf \ 
--pdf-engine=wkhtmltopdf \ 
--pdf-engine-opt="--enable-local-file-access" \
  --pdf-engine-opt="--page-size=Letter" \ 
--pdf-engine-opt="--margin-top=18mm" \
  --pdf-engine-opt="--margin-bottom=18mm" \ 
--pdf-engine-opt="--margin-left=22mm" \ 
--pdf-engine-opt="--margin-right=22mm" \
  --metadata title="Shop Sergeant — System Requirements" \ 
-o "$OUTPUT" \ 
"$INPUT"

echo "PDF written to: $OUTPUT"

Or just run it inline right now:

cd /home/jeff/src/projects/makersmiths/shop-sergeant/docs && \ 
pandoc \ 
--from=gfm \ 
--to=pdf \ 
--pdf-engine=wkhtmltopdf \
  --pdf-engine-opt="--enable-local-file-access" \ 
--pdf-engine-opt="--page-size=Letter" \ 
--pdf-engine-opt="--margin-top=18mm" \
  --pdf-engine-opt="--margin-bottom=18mm" \ 
--pdf-engine-opt="--margin-left=22mm" \
  --pdf-engine-opt="--margin-right=22mm" \ 
-o requirements.pdf \ 
requirements.md && echo "Done: docs/requirements.pdf"
