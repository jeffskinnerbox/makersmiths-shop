    {
      "type": "text",
      "id": "track2_text",
      "x": 570,
      "y": 168,
      "width": 420,
      "height": 226,
      "text": "Track 2 — Prototype Sprints\n(1 week each, throwaway)\n\n* P1: Claude API\n  (latency, tool use, context mgmt)\n* P2: Slack Integration\n  (bots, webhooks, interactivity)\n* P3: Google Sheets\n  (API limits, auth, sync model)\n* P4: Mobile (Android/iOS)\n  (push, offline, API proxy)",
      "originalText": "Track 2 — Prototype Sprints\n(1 week each, throwaway)\n\n* P1: Claude API\n  (latency, tool use, context mgmt)\n* P2: Slack Integration\n  (bots, webhooks, interactivity)\n* P3: Google Sheets\n  (API limits, auth, sync model)\n* P4: Mobile (Android/iOS)\n  (push, offline, API proxy)",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
